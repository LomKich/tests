<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_bg"
    android:elevation="16dp">

    <!-- ═══ DRAG HANDLE BAR (touch here to drag) ═══ -->
    <LinearLayout
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/drag_handle_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <!-- Drag icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⠿"
            android:textColor="#6e7681"
            android:textSize="16sp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_pause_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ TestSolver"
            android:textColor="#58a6ff"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_close"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="✕"
            android:textSize="12sp"
            android:textColor="#8b949e"
            android:backgroundTint="#21262d"
            android:padding="0dp"/>
    </LinearLayout>

    <!-- ═══ ANSWER CONTENT ═══ -->
    <TextView
        android:id="@+id/tv_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#e6edf3"
        android:textSize="14sp"
        android:lineSpacingExtra="5dp"
        android:padding="14dp"
        android:fontFamily="sans-serif"/>

</LinearLayout>
