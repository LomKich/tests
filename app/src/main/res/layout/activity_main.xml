<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="20dp"
    android:background="#0d1117">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎓 TestSolver"
        android:textSize="26sp"
        android:textColor="#58a6ff"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Материаловедение МПд,МПл-2-24"
        android:textSize="11sp"
        android:textColor="#6e7681"
        android:layout_marginBottom="20dp"/>

    <!-- Status block -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Проверка..."
        android:textColor="#c9d1d9"
        android:textSize="13sp"
        android:lineSpacingExtra="5dp"
        android:background="#161b22"
        android:padding="14dp"
        android:layout_marginBottom="16dp"/>

    <!-- Setup buttons -->
    <Button
        android:id="@+id/btn_accessibility"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="⚙ Настройки доступности"
        android:textSize="13sp"
        android:backgroundTint="#238636"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_overlay"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="🪟 Разрешить наложение окон"
        android:textSize="13sp"
        android:backgroundTint="#1f6feb"
        android:layout_marginBottom="20dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#21262d"
        android:layout_marginBottom="16dp"/>

    <!-- Controls -->
    <Button
        android:id="@+id/btn_pause"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="⏸ Пауза / Возобновить"
        android:textSize="13sp"
        android:backgroundTint="#6e4a9e"
        android:layout_marginBottom="8dp"
        android:enabled="false"/>

    <Button
        android:id="@+id/btn_add_question"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="➕ Добавить вопрос со скрина"
        android:textSize="13sp"
        android:backgroundTint="#b45309"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Как пользоваться:\n• Включи оба пункта выше\n• Открой Chrome → зайди на тест\n• Ответ появится внизу экрана\n• Потяни за заголовок панели чтобы переместить её\n• Кнопка Пауза — скрывает подсказки"
        android:textColor="#6e7681"
        android:textSize="12sp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
