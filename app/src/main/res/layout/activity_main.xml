<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0d1117">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎓"
        android:textSize="56sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TestSolver"
        android:textSize="28sp"
        android:textColor="#58a6ff"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Материаловедение МПд,МПл-2-24"
        android:textSize="12sp"
        android:textColor="#8b949e"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Проверка..."
        android:textColor="#c9d1d9"
        android:textSize="14sp"
        android:lineSpacingExtra="6dp"
        android:background="#161b22"
        android:padding="16dp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_accessibility"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="⚙ Открыть настройки доступности"
        android:textSize="14sp"
        android:backgroundTint="#238636"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_overlay"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="🪟 Разрешить наложение окон"
        android:textSize="14sp"
        android:backgroundTint="#1f6feb"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Как пользоваться:\n1. Включи оба пункта выше\n2. Открой Chrome и перейди на тест\n3. Ответ появится внизу экрана\n4. Для текстового поля — вставка автоматическая\n5. Для вариантов — нажми нужный"
        android:textColor="#6e7681"
        android:textSize="12sp"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>
